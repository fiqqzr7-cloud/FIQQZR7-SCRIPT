    SliderFrame.BackgroundColor3 = Color3_FromRGB(35, 35, 45)
    SliderFrame.BorderSizePixel = 0
    SliderFrame.Parent = parent
    CreateCorner(SliderFrame, 7)
    
    local SliderLabel = Instance.new("TextLabel")
    SliderLabel.Size = UDim2_New(1, -60, 0, 16)
    SliderLabel.Position = UDim2_New(0, 10, 0, 5)
    SliderLabel.BackgroundTransparency = 1
    SliderLabel.Text = sliderName
    SliderLabel.Font = Enum.Font.GothamBold
    SliderLabel.TextColor3 = ThemeColors.TextColor
    SliderLabel.TextSize = 11
    SliderLabel.TextXAlignment = Enum.TextXAlignment.Left
    SliderLabel.Parent = SliderFrame
    
    local ValueLabel = Instance.new("TextLabel")
    ValueLabel.Size = UDim2_New(0, 50, 0, 16)
    ValueLabel.Position = UDim2_New(1, -55, 0, 5)
    ValueLabel.BackgroundTransparency = 1
    ValueLabel.Text = tostring(defaultValue)
    ValueLabel.Font = Enum.Font.GothamBold
    ValueLabel.TextColor3 = ThemeColors.Stroke
    ValueLabel.TextSize = 11
    ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
    ValueLabel.Parent = SliderFrame
    
    local SliderTrack = Instance.new("Frame")
    SliderTrack.Size = UDim2_New(1, -24, 0, 4)
    SliderTrack.Position = UDim2_New(0, 12, 1, -12)
    SliderTrack.BackgroundColor3 = Color3_FromRGB(50, 50, 60)
    SliderTrack.BorderSizePixel = 0
    SliderTrack.Parent = SliderFrame
    CreateCorner(SliderTrack, UDim_New(1, 0).Offset)
    
    local SliderFill = Instance.new("Frame")
    SliderFill.Size = UDim2_New((defaultValue - minValue) / (maxValue - minValue), 0, 1, 0)
    SliderFill.BackgroundColor3 = ThemeColors.Stroke
    SliderFill.BorderSizePixel = 0
    SliderFill.Parent = SliderTrack
    CreateCorner(SliderFill, UDim_New(1, 0).Offset)
    
    local SliderKnob = Instance.new("TextButton")
    SliderKnob.Size = UDim2_New(0, 12, 0, 12)
    SliderKnob.Position = UDim2_New((defaultValue - minValue) / (maxValue - minValue), -6, 0.5, -6)
    SliderKnob.BackgroundColor3 = Color3_FromRGB(255, 255, 255)
    SliderKnob.BorderSizePixel = 0
    SliderKnob.Text = ""
    SliderKnob.AutoButtonColor = false
    SliderKnob.Parent = SliderTrack
    CreateCorner(SliderKnob, UDim_New(1, 0).Offset)
    
    local dragging = false
    
    local function updateSlider(input)
        local relativeX = math.clamp((input.Position.X - SliderTrack.AbsolutePosition.X) / SliderTrack.AbsoluteSize.X, 0, 1)
        local value = math.floor(minValue + (maxValue - minValue) * relativeX)
        
        ValueLabel.Text = tostring(value)
        SliderFill.Size = UDim2_New(relativeX, 0, 1, 0)
        SliderKnob.Position = UDim2_New(relativeX, -6, 0.5, -6)
        
        if onValueChanged then
            onValueChanged(value)
        end
    end
    
    SliderKnob.MouseButton1Down:Connect(function()
        dragging = true
    end)
    
    SliderTrack.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            updateSlider(input)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(input)
        end
    end)
    
    return SliderFrame
end

local function SetupSearchSystem(searchBox, clearButton, contentArea)
    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local searchText = string.lower(searchBox.Text)
        clearButton.Visible = searchText ~= ""
        
        if searchText == "" then
            for _, page in pairs(contentArea:GetChildren()) do
                if page:IsA("ScrollingFrame") then
                    local isHomePage = page.Name == "Home"
                    page.Visible = isHomePage
                    
                    for _, element in pairs(page:GetChildren()) do
                        if element:IsA("Frame") or element:IsA("TextButton") then
                            element.Visible = true
                        end
                    end
                end
            end
        else
            for _, page in pairs(contentArea:GetChildren()) do
                if page:IsA("ScrollingFrame") then
                    page.Visible = true
                    
                    for _, element in pairs(page:GetChildren()) do
                        if element:IsA("Frame") or element:IsA("TextButton") then
                            local elementName = string.lower(element.Name)
                            local isMatch = string.find(elementName, searchText, 1, true) ~= nil
                            element.Visible = isMatch
                        end
                    end
                end
            end
        end
    end)
    
    clearButton.MouseButton1Click:Connect(function()
        searchBox.Text = ""
    end)
end

