local function LoadExternalScript(scriptName)
    local url = ExternalScripts[scriptName]
    if not url then
        warn("Script not found: " .. scriptName)
        return
    end
    
    local success, result = pcall(function()
        local scriptContent = game:HttpGet(url)
        return loadstring(scriptContent)
    end)
    
    if success and result then
        local executeSuccess, executeError = pcall(result)
        if executeSuccess then
            getgenv().Notify({
                Title = scriptName,
                Content = "LOADED SUCCESSFULLY",
                Duration = 3
            })
        else
            getgenv().Notify({
                Title = scriptName,
                Content = "EXECUTION ERROR",
                Duration = 3
            })
            warn("Execute error:", executeError)
        end
    else
        getgenv().Notify({
            Title = scriptName,
            Content = "LOAD ERROR",
            Duration = 3
        })
        warn("Load error:", result)
    end
end

