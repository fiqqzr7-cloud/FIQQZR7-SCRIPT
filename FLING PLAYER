-- ===== FLING SELECTED =====
local function FlingSelected()
    if #selectedPlayers == 0 then
        statusLabel.Text = "❌ No players!"
        return
    end
    
    isFlinging = true
    stopFling = false
    startFlingBtn.BackgroundColor3 = Color3.fromRGB(100, 20, 20)
    startFlingBtn.Text = "⚡ FLINGING"
    stopFlingBtn.BackgroundColor3 = Color3.fromRGB(140, 30, 30)
    
    local success = 0
    for i, target in ipairs(selectedPlayers) do
        if stopFling then
            statusLabel.Text = "⏹️ Stopped!"
            break
        end
        
        statusLabel.Text = "💥 " .. target.Name .. " (" .. i .. "/" .. #selectedPlayers .. ")"
        
        local ok = pcall(function()
            SkidFling(target)
        end)
        
        if ok then
            success = success + 1
        end
        
        task.wait(0.2)
    end
    
    statusLabel.Text = "✅ " .. success .. "/" .. #selectedPlayers
    startFlingBtn.BackgroundColor3 = Color3.fromRGB(180, 20, 20)
    startFlingBtn.Text = "💥 START"
    stopFlingBtn.BackgroundColor3 = Color3.fromRGB(80, 20, 20)
    isFlinging = false
    stopFling = false
end

