-- ===== PLAYER BUTTONS =====
playerButtons = {}

local function createPlayerButtons()
    -- Clear old
    for _, btn in ipairs(playerButtons) do
        btn:Destroy()
    end
    playerButtons = {}
    selectedPlayers = {}
    
    -- Get players
    local players = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= Player then
            table.insert(players, plr)
        end
    end
    
    -- Sort
    table.sort(players, function(a, b) return a.Name < b.Name end)
    
    -- Create buttons (lebih kecil)
    for _, plr in ipairs(players) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0.95, 0, 0, 24)
        btn.BackgroundColor3 = Color3.fromRGB(25, 10, 10)
        btn.BorderSizePixel = 0
        btn.Text = plr.Name .. " [" .. plr.DisplayName:sub(1, 5) .. "]"
        btn.TextColor3 = Color3.fromRGB(200, 200, 200)
        btn.Font = Enum.Font.Gotham
        btn.TextSize = 9
        btn.Parent = playerFrame
        
        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 4)
        btnCorner.Parent = btn
        
        btn:SetAttribute("Selected", false)
        
        btn.MouseButton1Click:Connect(function()
            local selected = btn:GetAttribute("Selected")
            local newState = not selected
            
            btn:SetAttribute("Selected", newState)
            
            if newState then
                btn.BackgroundColor3 = Color3.fromRGB(40, 80, 40)
                btn.TextColor3 = Color3.fromRGB(255, 255, 255)
                table.insert(selectedPlayers, plr)
            else
                btn.BackgroundColor3 = Color3.fromRGB(25, 10, 10)
                btn.TextColor3 = Color3.fromRGB(200, 200, 200)
                for i, p in ipairs(selectedPlayers) do
                    if p == plr then
                        table.remove(selectedPlayers, i)
                        break
                    end
                end
            end
            
            -- Update select all button text
            if #selectedPlayers == #players then
                selectAllBtn.Text = "👥 DESELECT"
            else
                selectAllBtn.Text = "👥 SELECT ALL"
            end
        end)
        
        table.insert(playerButtons, btn)
    end
end

