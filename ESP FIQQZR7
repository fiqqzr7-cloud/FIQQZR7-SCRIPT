    Card.Parent = ScrollingFrame

    local CardCorner = Instance.new("UICorner")
    CardCorner.CornerRadius = UDim.new(0, 8)  -- Kurang bulat
    CardCorner.Parent = Card

    -- Inner gradient (MERAH)
    local CardGradient = Instance.new("UIGradient")
    CardGradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(35, 12, 15)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(22, 8, 10))
    })
    CardGradient.Rotation = 90
    CardGradient.Parent = Card

    -- Icon (MERAH)
    local IconLabel = Instance.new("TextLabel")
    IconLabel.Size = UDim2.new(0, 30, 1, 0)  -- Lebih kecil (40 -> 30)
    IconLabel.Position = UDim2.new(0, 6, 0, 0)
